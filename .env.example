# ===========================================
# 智能客服 Agent 环境变量配置
# 复制此文件为 .env 并填入实际值
# ===========================================

# ---------- 数据库 ----------
POSTGRES_USER=smartcs
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=smartcs

# ---------- Redis ----------
REDIS_PASSWORD=your_redis_password_here

# ---------- MinIO (Milvus 存储后端) ----------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_secret_here

# ---------- Dify ----------
SECRET_KEY=your_random_secret_key_here
INIT_PASSWORD=your_dify_admin_password_here

# ---------- LLM API ----------
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# ---------- 向量嵌入 ----------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ---------- Milvus ----------
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ---------- 服务端口 ----------
ORDER_SERVICE_PORT=8001
LOGISTICS_SERVICE_PORT=8002
TICKET_SERVICE_PORT=8003
KNOWLEDGE_SERVICE_PORT=8004

# ---------- 日志 ----------
LOG_LEVEL=INFO

# ---------- 网关 ----------
GATEWAY_PORT=8000

# ---------- Kafka ----------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
